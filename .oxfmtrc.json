{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "endOfLine": "lf",
  "semi": false,
  "singleQuote": false,
  "tabWidth": 2,
  "trailingComma": "es5",
  "printWidth": 80,
  "ignorePatterns": [
    "dist/**",
    "node_modules/**",
    ".next/**",
    ".turbo/**",
    "coverage/**",
    "pnpm-lock.yaml",
    ".pnpm-store/**",
    "apps/web/next-env.d.ts",
    "bun.lock"
  ],
  "sortTailwindcss": {
    "stylesheet": "packages/ui/src/styles/globals.css",
    "functions": ["cn", "cva"]
  }
}
