{
  "name": "writing-app",
  "version": "0.0.1",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo build",
    "build-storybook": "bun --filter storybook build",
    "dev": "turbo dev",
    "db:reset": "bun --filter api db:reset",
    "lint": "turbo lint",
    "format": "turbo format",
    "seed": "bun --filter api seed",
    "storybook": "bun --filter storybook dev",
    "test": "bun --filter api test",
    "typecheck": "turbo typecheck",
    "prepare": "lefthook install"
  },
  "devDependencies": {
    "@workspace/eslint-config": "workspace:*",
    "@workspace/typescript-config": "workspace:*",
    "lefthook": "^2.1.3",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "turbo": "^2.8.8",
    "typescript": "5.9.3"
  },
  "packageManager": "bun@1.3.10",
  "engines": {
    "node": "20.x"
  }
}
