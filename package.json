{
  "name": "writing-app",
  "version": "0.0.1",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo build",
    "build-storybook": "bun --filter storybook build",
    "dev": "turbo dev",
    "dev:local": "bun --filter web dev:local",
    "db:reset": "bun --filter api db:reset",
    "lint": "turbo lint",
    "format": "turbo format",
    "seed": "bun --filter api seed",
    "storybook": "bun --filter storybook dev",
    "test": "bun run typecheck:phase-one && bun run test:unit && bun run test:e2e",
    "test:coverage": "bunx --bun vitest run --config vitest.workspace.ts --coverage",
    "test:e2e": "bun --filter web test:e2e",
    "test:unit": "turbo test --filter=api --filter=web --filter=@workspace/backend-core --filter=@workspace/db",
    "typecheck:phase-one": "turbo typecheck --filter=api --filter=web --filter=@workspace/backend-core --filter=@workspace/db",
    "typecheck": "turbo typecheck",
    "prepare": "lefthook install"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.0",
    "@workspace/eslint-config": "workspace:*",
    "@workspace/typescript-config": "workspace:*",
    "bun-types": "^1.3.11",
    "jsdom": "^29.0.0",
    "lefthook": "^2.1.3",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "turbo": "^2.8.8",
    "typescript": "5.9.3",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.1.0"
  },
  "packageManager": "bun@1.3.10",
  "engines": {
    "node": "20.x"
  }
}
