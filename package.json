{
  "name": "writing-app",
  "version": "0.0.1",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo build",
    "build-storybook": "bun --filter storybook build",
    "dev": "turbo dev",
    "dev:local": "bun --filter web dev:local",
    "db:reset": "bun --filter api db:reset",
    "lint": "turbo lint",
    "lint:oxlint": "oxlint",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "seed": "bun --filter api seed",
    "storybook": "bun --filter storybook dev",
    "test": "bun run typecheck:apps && bun run test:unit && bun run test:e2e",
    "test:coverage": "bunx --bun vitest run --config vitest.workspace.ts --coverage",
    "test:e2e": "bun --filter web test:e2e",
    "test:unit": "turbo test --filter=api --filter=web --filter=@workspace/core --filter=@workspace/database",
    "typecheck:apps": "turbo typecheck --filter=api --filter=web --filter=@workspace/core --filter=@workspace/database",
    "typecheck": "turbo typecheck",
    "prepare": "lefthook install"
  },
  "dependencies": {
    "openapi-fetch": "^0.17.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.0",
    "@workspace/config": "workspace:*",
    "bun-types": "^1.3.11",
    "eslint-plugin-oxlint": "^1.57.0",
    "jsdom": "^29.0.0",
    "lefthook": "^2.1.3",
    "openapi-typescript": "^7.13.0",
    "oxfmt": "^0.42.0",
    "oxlint": "^1.57.0",
    "turbo": "^2.8.8",
    "typescript": "5.9.3",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.1.0",
    "web": "workspace:*"
  },
  "engines": {
    "node": "20.x"
  },
  "packageManager": "bun@1.3.10"
}
