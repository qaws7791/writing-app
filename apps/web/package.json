{
  "name": "web",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "api:generate": "bun run --filter=@workspace/api-client api:generate",
    "api:fetch": "bun run --filter=@workspace/api-client api:fetch",
    "dev": "bun --env-file=.env.development --bun next dev",
    "dev:local": "bun --env-file=.env.local-mode --bun next dev",
    "build": "bun --env-file=.env.development --bun next build",
    "start": "bun --env-file=.env.development --bun next start",
    "lint": "eslint",
    "format": "oxfmt .",
    "lint:oxlint": "oxlint",
    "test": "vitest run --config vitest.config.ts --pool=forks --maxWorkers=1 --no-file-parallelism",
    "test:e2e": "playwright test --config playwright.config.ts",
    "test:watch": "vitest watch --config vitest.config.ts --pool=forks --maxWorkers=1 --no-file-parallelism",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@hugeicons/core-free-icons": "^4.0.0",
    "@hugeicons/react": "^1.1.5",
    "@solar-icons/react": "^1.1.0",
    "@t3-oss/env-nextjs": "^0.13.10",
    "@tanstack/react-query": "^5.95.2",
    "@tiptap/extension-blockquote": "^3.20.1",
    "@tiptap/extension-bold": "^3.20.1",
    "@tiptap/extension-character-count": "^3.20.1",
    "@tiptap/extension-document": "^3.20.1",
    "@tiptap/extension-history": "^3.20.1",
    "@tiptap/extension-paragraph": "^3.20.1",
    "@tiptap/extension-placeholder": "^3.20.1",
    "@tiptap/extension-text": "^3.20.1",
    "@tiptap/extension-typography": "^3.20.1",
    "@tiptap/pm": "^3.20.1",
    "@tiptap/react": "^3.20.1",
    "@workspace/api-client": "workspace:*",
    "@workspace/ui": "workspace:*",
    "@xstate/react": "^6.1.0",
    "better-auth": "^1.3.4",
    "dexie": "^4.3.0",
    "dompurify": "^3.3.3",
    "next": "16.1.6",
    "next-themes": "^0.4.6",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-hook-form": "^7.72.0",
    "turndown": "^7.2.2",
    "xstate": "^5.28.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.1.18",
    "@types/bun": "^1.3.10",
    "@types/dompurify": "^3.2.0",
    "@types/react": "^19.2.10",
    "@types/react-dom": "^19.2.3",
    "@types/turndown": "^5.0.6",
    "@workspace/config": "workspace:*",
    "babel-plugin-react-compiler": "^1.0.0",
    "eslint": "^9.39.2",
    "typescript": "^5.9.3"
  }
}
