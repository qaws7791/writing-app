{
  "name": "web",
  "version": "0.0.1",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "bun --env-file=.env.development --bun next dev",
    "dev:local": "bun --env-file=.env.local-mode --bun next dev",
    "build": "bun --env-file=.env.development --bun next build",
    "start": "bun --env-file=.env.development --bun next start",
    "lint": "eslint",
    "format": "prettier --write --ignore-path ../../.prettierignore \"**/*.{ts,tsx}\"",
    "test": "node ../../node_modules/vitest/vitest.mjs run --config vitest.config.ts --pool=forks --maxWorkers=1 --no-file-parallelism",
    "test:e2e": "node ../../node_modules/@playwright/test/cli.js test --config playwright.config.ts",
    "test:watch": "node ../../node_modules/vitest/vitest.mjs watch --config vitest.config.ts --pool=forks --maxWorkers=1 --no-file-parallelism",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@hugeicons/core-free-icons": "^4.0.0",
    "@hugeicons/react": "^1.1.5",
    "@solar-icons/react": "^1.1.0",
    "@t3-oss/env-nextjs": "^0.13.10",
    "@tiptap/extension-blockquote": "^3.20.1",
    "@tiptap/extension-bold": "^3.20.1",
    "@tiptap/extension-character-count": "^3.20.1",
    "@tiptap/extension-document": "^3.20.1",
    "@tiptap/extension-history": "^3.20.1",
    "@tiptap/extension-paragraph": "^3.20.1",
    "@tiptap/extension-placeholder": "^3.20.1",
    "@tiptap/extension-text": "^3.20.1",
    "@tiptap/extension-typography": "^3.20.1",
    "@tiptap/pm": "^3.20.1",
    "@tiptap/react": "^3.20.1",
    "@workspace/backend-core": "workspace:*",
    "@workspace/ui": "workspace:*",
    "better-auth": "^1.3.4",
    "next": "16.1.6",
    "next-themes": "^0.4.6",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.1.18",
    "@types/bun": "^1.3.10",
    "@types/react": "^19.2.10",
    "@types/react-dom": "^19.2.3",
    "@workspace/eslint-config": "workspace:^",
    "@workspace/typescript-config": "workspace:*",
    "eslint": "^9.39.2",
    "typescript": "^5.9.3"
  }
}
