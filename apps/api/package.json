{
  "name": "api",
  "type": "module",
  "scripts": {
    "build:deps": "bun run src/scripts/build-workspace-deps.ts",
    "prepare:deps": "bun run build:deps && bun run src/scripts/sync-workspace-deps.ts",
    "db:reset": "bun run prepare:deps && bun --env-file=.env.development run src/scripts/db-reset.ts",
    "dev": "bun run src/scripts/dev.ts",
    "dev:server": "bun --env-file=.env.development run --hot src/index.ts",
    "lint": "eslint . --ignore-pattern .workspace-deps",
    "seed": "bun run prepare:deps && bun --env-file=.env.development run src/scripts/seed.ts",
    "test": "node ../../node_modules/vitest/vitest.mjs run --config vitest.config.ts --pool=forks --maxWorkers=1 --no-file-parallelism",
    "test:serve": "bun run prepare:deps && bun --env-file=.env.test run src/scripts/db-reset.ts && bun --env-file=.env.test run src/index.ts",
    "test:watch": "node ../../node_modules/vitest/vitest.mjs watch --config vitest.config.ts --pool=forks --maxWorkers=1 --no-file-parallelism",
    "typecheck": "bun run prepare:deps && tsc --noEmit"
  },
  "dependencies": {
    "@t3-oss/env-core": "^0.13.10",
    "@workspace/backend-core": "workspace:*",
    "@workspace/db": "workspace:*",
    "better-auth": "^1.3.4",
    "hono": "^4.12.5",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/bun": "^1.3.10",
    "@workspace/eslint-config": "workspace:*",
    "@workspace/typescript-config": "workspace:*",
    "eslint": "^9.39.2"
  }
}
