{
  "name": "api",
  "type": "module",
  "scripts": {
    "db:reset": "cd ../../ && bun --env-file=apps/api/.env.development run apps/api/src/scripts/db-reset.ts",
    "dev": "cd ../../ && bun --env-file=apps/api/.env.development run --hot apps/api/src/index.ts",
    "lint": "eslint .",
    "seed": "cd ../../ && bun --env-file=apps/api/.env.development run apps/api/src/scripts/seed.ts",
    "test": "node ../../node_modules/vitest/vitest.mjs run --config vitest.config.ts --pool=forks --maxWorkers=1 --no-file-parallelism",
    "test:serve": "bun --env-file=.env.test run src/scripts/db-reset.ts && bun --env-file=.env.test run src/index.ts",
    "test:watch": "node ../../node_modules/vitest/vitest.mjs watch --config vitest.config.ts --pool=forks --maxWorkers=1 --no-file-parallelism",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@hono/zod-openapi": "^1.2.3",
    "@scalar/hono-api-reference": "^0.10.4",
    "@t3-oss/env-core": "^0.13.10",
    "@workspace/ai": "workspace:*",
    "@workspace/core": "workspace:*",
    "@workspace/database": "workspace:*",
    "better-auth": "^1.3.4",
    "hono": "^4.12.5",
    "neverthrow": "^8.2.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bun": "^1.3.10",
    "@workspace/config": "workspace:*",
    "eslint": "^9.39.2"
  }
}
