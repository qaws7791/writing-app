{
  "name": "api",
  "type": "module",
  "scripts": {
    "db:reset": "bun --env-file=.env.development run src/scripts/db-reset.ts",
    "dev": "bun --env-file=.env.development run --hot src/index.ts",
    "lint": "eslint .",
    "seed": "bun --env-file=.env.development run src/scripts/seed.ts",
    "test": "node ../../node_modules/vitest/vitest.mjs run --config vitest.config.ts --pool=forks --maxWorkers=1 --no-file-parallelism",
    "test:serve": "bun --env-file=.env.test run src/scripts/db-reset.ts && bun --env-file=.env.test run src/index.ts",
    "test:watch": "node ../../node_modules/vitest/vitest.mjs watch --config vitest.config.ts --pool=forks --maxWorkers=1 --no-file-parallelism",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@t3-oss/env-core": "^0.13.10",
    "@workspace/application": "workspace:*",
    "@workspace/domain": "workspace:*",
    "@workspace/infrastructure": "workspace:*",
    "hono": "^4.12.5",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/bun": "^1.3.10",
    "@workspace/eslint-config": "workspace:*",
    "@workspace/typescript-config": "workspace:*",
    "eslint": "^9.39.2"
  }
}
