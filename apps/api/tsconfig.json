{
  "extends": "@workspace/typescript-config/base.json",
  "compilerOptions": {
    "baseUrl": ".",
    "module": "ES2022",
    "moduleResolution": "bundler",
    "paths": {
      "@workspace/backend-core": [
        "./.workspace-deps/node_modules/@workspace/backend-core/index"
      ],
      "@workspace/backend-core/*": [
        "./.workspace-deps/node_modules/@workspace/backend-core/*"
      ],
      "@workspace/db": ["./.workspace-deps/node_modules/@workspace/db/index"],
      "@workspace/db/*": ["./.workspace-deps/node_modules/@workspace/db/*"]
    },
    "strict": true,
    "types": ["bun-types", "vitest/globals"]
  },
  "include": ["src/**/*.ts"]
}
